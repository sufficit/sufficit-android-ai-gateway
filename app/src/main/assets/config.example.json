{
  "_comment": "Template do seed de configuracao. Copie para config.json (no mesmo diretorio assets/, ignorado pelo git) para embutir um seed proprio no build, ou deixe sem config.json e preencha host/tokens pela tela de configuracao do app na primeira inicializacao. NUNCA comite config.json com credenciais reais.",
  "schema": "openclaw-android-settings",
  "version": 1,
  "settings": {
    "general": {
      "autoStart": true,
      "cameraGestureEnabled": true,
      "development": false
    },
    "connection": {
      "serverAddress": "your-openclaw-host.example.com",
      "gatewayToken": "",
      "deviceToken": "",
      "sessionKey": "",
      "localEndpointUrl": "ws://192.168.0.10:8787/room-audio"
    },
    "transcription": {
      "mode": "remote",
      "remoteModel": "large-v3-turbo",
      "whisperUrl": "https://your-whisper-host.example.com/v1/audio/transcriptions",
      "whisperToken": "",
      "localModel": "/data/user/0/com.sufficit.openclaw.gateway/files/models/sherpa-whisper-tiny",
      "localExecution": "nnapi",
      "terms": "",
      "dictionary": "",
      "repeatSuppression": 0.72,
      "colloquialNormalization": 0.35
    },
    "whisper": {
      "vadFilter": true,
      "conditionOnPreviousText": false,
      "noSpeechThreshold": 0.72,
      "compressionRatioThreshold": 2.2,
      "repetitionPenalty": 1.12
    },
    "audio": {
      "vadThreshold": 0.015,
      "autoSensitivity": true,
      "gain": 2.4,
      "noiseGateMultiplier": 1.8,
      "minSpeechRms": 0.010,
      "minSpeechPeakNormalized": 0.035,
      "minSpeechCandidateFrames": 3,
      "maxTransientCrestFactor": 5.8,
      "minZeroCrossingRate": 0.015,
      "maxZeroCrossingRate": 0.24,
      "ambientStabilityThreshold": 0.66,
      "ambientGainStabilityThreshold": 0.35,
      "ambientDynamicContrastMax": 0.050,
      "ambientRmsVarianceMax": 0.22,
      "ambientSpectrumMotionMax": 0.060,
      "ambientSpeechPenalty": 0.20,
      "ambientDetectionHoldFrames": 6,
      "ambientDetectionReleaseFrames": 4,
      "ambientSpeechOverrideDynamicContrast": 0.050,
      "ambientSpeechOverrideSpectrumMotion": 0.090,
      "ambientGainFactor": 0.58,
      "ambientGainStabilityReduction": 0.22,
      "ambientGainMinGain": 0.55,
      "ambientGainSmoothingFast": 0.40,
      "ambientGainSmoothingSlow": 0.14
    },
    "assistant": {
      "voiceEnabled": true,
      "voiceStyle": "feminine",
      "speechRate": 1.8,
      "pitch": 1.0
    },
    "voiceChannel": {
      "enabled": true,
      "wakeTerms": "assistant\nagent",
      "followUpSecs": 12,
      "idlePromptSecs": 300,
      "accumulationWindowSecs": 4
    },
    "screen": {
      "mode": "activity",
      "holdSeconds": 4
    },
    "card": {
      "clearTimeoutSecs": 30
    }
  }
}
